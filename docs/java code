        CarpoolSystem system = new CarpoolSystem();
        String[][] driverData = {
            {"Arun",  "Swift",       "TN38AB1234", "Chennai"},
            {"Rahul", "Hyundai i20", "TN37CD5678", "Coimbatore"},
            {"Vijay", "Honda City",  "TN58EF9876", "Madurai"}
        };
        String[][] customerData = {
            {"Karthik", "Chennai",     "Tambaram",     "Chromepet"},
            {"Suresh",  "Coimbatore",  "Gandhipuram",  "Ukkadam"},
            {"Priya",   "Madurai",     "Trichy",       "Mattuthavani"}
        };
        List<Ride> createdRides = new ArrayList<>();
        for (int i = 0; i < driverData.length; i++) {
            Driver driver = new Driver(driverData[i][0], driverData[i][1], driverData[i][2], driverData[i][3]);
            Customer customer = new Customer(customerData[i][0], customerData[i][1], customerData[i][2], customerData[i][3]);
            Ride ride = new Ride(driver, customer);
